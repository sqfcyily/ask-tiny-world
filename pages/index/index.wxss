page {
  height: 100%;
}

.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 声音开关 */
.sound-toggle {
  position: absolute;
  left: 15px;
  z-index: 10;
  background: rgba(255, 255, 255, 0.8);
  border: 2px solid #E8D5C4;
  border-radius: 20px;
  padding: 6px 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.sound-toggle:active {
  transform: scale(0.9);
}

.sound-icon {
  font-size: 20px;
  transition: all 0.3s;
}

.sound-on {
  animation: pulse-zoom 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes pulse-zoom {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.sound-off {
  filter: grayscale(100%) opacity(0.6);
  animation: none; /* 关闭声音时停止动画 */
}

.chat-area {
  flex: 1;
  position: relative;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.ai-bubble-container {
  position: absolute;
  bottom: 68vh; /* 将气泡容器底部固定在距离屏幕底部50%视口高度的位置（刚好在小动物上方） */
  left: 50%;
  transform: translateX(-50%);
  width: 85%; /* 恢复外层容器的宽度，提供最大的伸展空间 */
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* ✨让整个气泡内容区域在最外层容器中靠左对齐 */
  /* 限制最大高度，防止顶出屏幕，这里留出顶部胶囊按钮和安全距离的空间 */
  max-height: calc(50vh - 80px); 
}

/* 新增的内层包裹器，用来让气泡和小尾巴作为一个整体去适应内容宽度 */
.bubble-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-start; /* 内部靠左对齐，保证尾巴相对气泡位置稳定 */
  width: max-content; /* 宽度由内容决定 */
  min-width: 50%; /* 最小宽度为容器的 50% */
  max-width: 100%; /* 最大不能超过父容器 */
  
  /* 调整气泡在 85% 容器中的起始位置 */
  /* 虽然容器靠左对齐了，但我们可以用一点 margin 把它稍微往中间推一点点，对准小动物 */
  margin-left: 10%; 
}

.ai-bubble {
  background: #FFF9F0;
  border: 3px solid #E8D5C4;
  border-radius: 24px;
  box-shadow: 0 8px 16px rgba(0,0,0,0.08);
  position: relative;
  
  /* 气泡占满 wrapper 的宽度 */
  width: 100%; 
  
  box-sizing: border-box;
  /* 让 scroll-view 的高度根据内容自适应，但受限于外层 max-height */
  height: auto; 
  max-height: 100%;
}

/* 内部内容增加 padding */
.bubble-content {
  padding: 16px 20px;
  box-sizing: border-box;
}

.msg-text {
  font-size: 16px;
  line-height: 1.5;
  color: #5D4037;
  font-weight: 500;
  word-break: break-all;
  display: inline-block; /* 配合 max-content，让文字撑开宽度 */
}

/* 富文本中的段落样式，控制段落间距 */
.msg-paragraph {
  margin-bottom: 6px; /* 减小换行后的空行高度 */
}
.msg-paragraph:last-child {
  margin-bottom: 0;
}

.bubble-tail {
  position: relative; /* 尾巴跟在气泡下面 */
  /* 让尾巴始终保持在自身容器偏左的位置 */
  align-self: flex-start;
  margin-left: 25px; /* 尾巴距离气泡左边缘固定 25px */
  width: 0;
  height: 0;
  border-left: 15px solid transparent;
  border-right: 15px solid transparent;
  border-top: 18px solid #E8D5C4;
  margin-top: -3px; /* 盖住一点点气泡的边框 */
  z-index: 4;
}

.bubble-tail::after {
  content: '';
  position: absolute;
  top: -19px;
  left: -11px;
  width: 0;
  height: 0;
  border-left: 11px solid transparent;
  border-right: 11px solid transparent;
  border-top: 14px solid #FFF9F0;
}

.bottom-padding {
  height: 160px; /* 留出底部按钮的空间，防止滚动不到底 */
}

.input-area {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 250px; /* 给整个操作区足够的高度，以便自由定位 */
  z-index: 10;
  pointer-events: none; /* 让空白区域不阻挡底层的点击事件 */
}

.btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center; /* 确保内容垂直居中 */
  position: absolute; /* 使用绝对定位，打破传统的水平排列 */
  pointer-events: auto; /* 恢复按钮本身的点击能力 */
}

/* 语音按钮：放在正下方偏左一点（图中花朵的位置） */
.voice-btn-container {
  bottom: 30px;
  left: 45%;
  transform: translateX(-50%);
}

/* 文本按钮：放在右下角偏上（图中信箱的位置） */
.text-btn-container {
  bottom: 80px;
  right: 15px;
}

.btn-icon {
  transition: all 0.2s ease;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 80px; /* 如果没有图片，emoji也会很大 */
}

.text-bubble-hint {
  background: #fff;
  padding: 6px 18px; /* 增大内边距 */
  border-radius: 20px; /* 增大圆角 */
  font-size: 16px; /* 增大字体 */
  color: #8D6E63;
  font-weight: bold;
  border: 2px dashed #D7CCC8;
  position: relative; /* 改为相对定位，自然排在上方 */
  display: inline-block;
  box-shadow: 0 4px 8px rgba(0,0,0,0.05);
}

.voice-hint {
  animation: none; /* 说话按钮上面的气泡不需要飘浮动画 */
}

.text-hint {
  animation: float 2.5s ease-in-out infinite;
}

.text-bubble-hint::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  border-left: 6px solid transparent;
  border-right: 6px solid transparent;
  border-top: 8px solid #D7CCC8;
}

/* 动画效果 */
.floating {
  animation: float 2.5s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

.recording {
  animation: pulse 1.5s infinite;
  filter: drop-shadow(0 0 10px rgba(255, 138, 128, 0.8));
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

/* 文本输入弹窗 */
.text-input-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

/* 历史对话弹窗样式 */
.history-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  backdrop-filter: blur(2px);
}

.history-box {
  width: 88%;
  height: 70vh;
  background: #FFF9F0;
  border-radius: 24px;
  border: 4px solid #FFCA28;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
  overflow: hidden;
  animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes popIn {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.history-header {
  height: 60px;
  background: #FFCA28;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  border-bottom: 3px solid #FFB300;
}

.history-title {
  font-size: 20px;
  font-weight: bold;
  color: #5D4037;
  text-shadow: 1px 1px 0px rgba(255,255,255,0.5);
}

.history-close {
  position: absolute;
  right: 15px;
  top: 15px;
  width: 32px;
  height: 32px;
  background: #FF8A65; /* 温暖的橘红色背景 */
  border-radius: 10px; /* 带大圆角的正方形 */
  text-align: center;
  line-height: 32px;
  font-weight: 900;
  font-size: 18px;
  color: #fff;
  box-shadow: 0 3px 0 #D84315, 0 4px 6px rgba(0, 0, 0, 0.15); /* 底部厚度阴影，模拟实体按键 */
  border: 2px solid #fff; /* 加一圈白边，更像贴纸 */
  transition: all 0.1s ease; /* 动画加快，让按压更干脆 */
}

.history-clear {
  position: absolute;
  left: 15px;
  top: 15px;
  width: 32px;
  height: 32px;
  background: #4DD0E1; /* 清新的浅蓝色背景 */
  border-radius: 10px; /* 带大圆角的正方形 */
  text-align: center;
  line-height: 32px;
  font-size: 18px;
  box-shadow: 0 3px 0 #00ACC1, 0 4px 6px rgba(0, 0, 0, 0.15); /* 底部厚度阴影，模拟实体按键 */
  border: 2px solid #fff; /* 加一圈白边 */
  transition: all 0.1s ease;
}

.history-close:active, .history-clear:active {
  transform: translateY(3px) scale(0.95); /* 按下去的时候感觉被压扁了 */
  box-shadow: 0 0 0 transparent, 0 1px 2px rgba(0, 0, 0, 0.1); /* 按下时厚度消失 */
}

.history-scroll {
  flex: 1;
  padding: 15px;
  box-sizing: border-box;
  height: 0; /* 强制 flex 子项计算高度，解决 scroll-view 在 flex 布局中不滚动的问题 */
}

.history-list {
  display: flex;
  flex-direction: column;
  padding-bottom: 20px;
}

.history-item {
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* 历史记录里的气泡通用样式 */
.history-q-box {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  align-self: flex-end; /* 改为靠右对齐，代表小朋友发出的消息 */
  max-width: 85%;
}

.history-a-box {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  align-self: flex-start; /* 靠左对齐，代表AI回复 */
  max-width: 85%;
}

.history-avatar {
  font-size: 30px;
  background: #fff;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2px solid #E8D5C4;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  flex-shrink: 0;
}

.history-bubble {
  padding: 12px 16px;
  border-radius: 18px;
  font-size: 15px;
  line-height: 1.5;
  color: #5D4037;
  word-break: break-all;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  position: relative;
}

.user-bubble {
  background: #E3F2FD;
  border: 2px solid #BBDEFB;
  border-top-right-radius: 4px; /* 因为头像在右边，所以右上角为直角，模拟对话尾巴 */
}

.ai-history-bubble {
  background: #FFF;
  border: 2px solid #E8D5C4;
  border-top-left-radius: 4px; /* 头像在左边，左上角为直角 */
}

.text-input-box {
  background: #fff;
  padding: 16px 20px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
}

.input-element {
  flex: 1;
  background: #F5F5F5;
  height: 44px;
  border-radius: 22px;
  padding: 0 20px;
  font-size: 16px;
  color: #333;
}

.send-btn {
  margin-left: 16px;
  background: #FFCA28;
  color: #fff;
  padding: 0 24px;
  height: 44px;
  line-height: 44px;
  border-radius: 22px;
  font-weight: bold;
  font-size: 16px;
  box-shadow: 0 4px 10px rgba(255, 202, 40, 0.4);
}

.send-btn:active {
  background: #FFB300;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 24px;
  padding: 0 8px;
}
.dot {
  width: 8px;
  height: 8px;
  background: #8D6E63;
  border-radius: 50%;
  margin: 0 4px;
  animation: bounce 1.4s infinite ease-in-out both;
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 左侧草地上的信封收集区 */
.envelopes-container {
  position: absolute;
  bottom: 25vh; /* 刚好在男孩左边的草地上，狐狸下方 */
  left: 18vw;
  width: 60px;
  height: 60px;
  z-index: 4; /* 在背景之上，气泡层之下 */
  border-radius: 50%; /* 让光晕更均匀地包裹这片区域 */
}

/* 当有信封时，整个容器一起闪动光晕 */
.container-glow {
  animation: pulse 1.5s infinite;
  /* 整体外层光晕效果，颜色更柔和贴合草地 */
  filter: drop-shadow(0 0 12px rgba(255, 138, 128, 0.8));
}

.envelope-wrapper {
  position: absolute;
  left: 0;
  top: 0;
  transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); /* 掉落时的Q弹效果 */
}

.envelope-item {
  font-size: 45px;
  /* 移除单独的光晕，改由外层 container-glow 负责 */
}