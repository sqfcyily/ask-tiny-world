page {
  height: 100%;
}

.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  background: linear-gradient(145deg, #c6e4ff 0%, #e0f0ff 100%);
  overflow: hidden;
}

.cloud {
  position: absolute;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50px;
}

.cloud::before, .cloud::after {
  content: '';
  position: absolute;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
}

.cloud-1 {
  width: 100px;
  height: 30px;
  top: 15%;
  left: 10%;
  animation: floatCloud 20s linear infinite;
}
.cloud-1::before {
  width: 40px;
  height: 40px;
  top: -20px;
  left: 15px;
}
.cloud-1::after {
  width: 50px;
  height: 50px;
  top: -25px;
  left: 40px;
}

.cloud-2 {
  width: 140px;
  height: 40px;
  top: 25%;
  right: -20px;
  animation: floatCloud 30s linear infinite reverse;
}
.cloud-2::before {
  width: 50px;
  height: 50px;
  top: -25px;
  left: 20px;
}
.cloud-2::after {
  width: 70px;
  height: 70px;
  top: -35px;
  left: 55px;
}

.cloud-3 {
  width: 120px;
  height: 35px;
  top: 60%;
  left: 20%;
  animation: floatCloud 25s linear infinite;
  opacity: 0.6;
}
.cloud-3::before {
  width: 45px;
  height: 45px;
  top: -20px;
  left: 20px;
}
.cloud-3::after {
  width: 60px;
  height: 60px;
  top: -30px;
  left: 50px;
}

@keyframes floatCloud {
  0% { transform: translateX(0); }
  50% { transform: translateX(30px); }
  100% { transform: translateX(0); }
}

.nav-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 44px;
  z-index: 10;
  padding-bottom: 10px;
}

.title {
  background: rgba(255, 243, 224, 0.95);
  padding: 8px 24px;
  border-radius: 24px;
  font-size: 18px;
  font-weight: bold;
  color: #8D6E63;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  border: 3px solid #fff;
}

.chat-list {
  flex: 1;
  padding: 20px 15px;
  box-sizing: border-box;
  z-index: 1;
  height: 100%;
}

.message-item {
  display: flex;
  margin-bottom: 24px;
  align-items: flex-start;
  width: 100%;
}

.user-msg {
  flex-direction: row;
  justify-content: flex-end;
}

.ai-msg {
  flex-direction: row;
  justify-content: flex-start;
}

.avatar {
  font-size: 32px;
  margin: 0 12px;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  flex-shrink: 0;
  border: 2px solid #fff;
}

.bubble {
  max-width: 65%;
  padding: 14px 18px;
  border-radius: 24px;
  font-size: 16px;
  line-height: 1.6;
  color: #4A4A4A;
  box-shadow: 0 6px 16px rgba(0,0,0,0.06);
  position: relative;
  word-break: break-all;
}

.user-msg .bubble {
  background: #E3F2FD;
  border-bottom-right-radius: 6px;
  border: 2px solid #BBDEFB;
}

.ai-msg .bubble {
  background: #FFF9C4;
  border-bottom-left-radius: 6px;
  border: 2px solid #FFF59D;
}

.bottom-padding {
  height: 160px;
}

.input-area {
  position: absolute;
  bottom: 40px;
  width: 100%;
  display: flex;
  justify-content: space-evenly;
  align-items: flex-end;
  z-index: 10;
  padding: 0 20px;
  box-sizing: border-box;
}

.btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn-icon {
  font-size: 54px;
  width: 88px;
  height: 88px;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8px 20px rgba(0,0,0,0.12);
  margin-bottom: 12px;
  border: 4px solid #fff;
  transition: all 0.2s ease;
}

.btn-icon:active {
  transform: scale(0.95);
}

.btn-text {
  background: rgba(255, 255, 255, 0.95);
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 15px;
  color: #5D4037;
  font-weight: bold;
  box-shadow: 0 4px 8px rgba(0,0,0,0.08);
  border: 2px solid #fff;
}

/* 动画效果 */
.floating {
  animation: float 2.5s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

.recording {
  animation: pulse 1.5s infinite;
  background: #FFCDD2;
  border-color: #FF8A80;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(255, 138, 128, 0.7); }
  70% { box-shadow: 0 0 0 20px rgba(255, 138, 128, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 138, 128, 0); }
}

/* 文本输入弹窗 */
.text-input-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.text-input-box {
  background: #fff;
  padding: 16px 20px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
}

.input-element {
  flex: 1;
  background: #F5F5F5;
  height: 44px;
  border-radius: 22px;
  padding: 0 20px;
  font-size: 16px;
  color: #333;
}

.send-btn {
  margin-left: 16px;
  background: #FFCA28;
  color: #fff;
  padding: 0 24px;
  height: 44px;
  line-height: 44px;
  border-radius: 22px;
  font-weight: bold;
  font-size: 16px;
  box-shadow: 0 4px 10px rgba(255, 202, 40, 0.4);
}

.send-btn:active {
  background: #FFB300;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 24px;
  padding: 0 8px;
}
.dot {
  width: 8px;
  height: 8px;
  background: #8D6E63;
  border-radius: 50%;
  margin: 0 4px;
  animation: bounce 1.4s infinite ease-in-out both;
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}