page {
  height: 100%;
}

.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.chat-area {
  flex: 1;
  position: relative;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.ai-bubble-container {
  position: absolute;
  bottom: 68vh; /* 将气泡容器底部固定在距离屏幕底部50%视口高度的位置（刚好在小动物上方） */
  left: 50%;
  transform: translateX(-50%);
  width: 85%;
  z-index: 5;
  display: flex;
  flex-direction: column;
  align-items: center;
  /* 限制最大高度，防止顶出屏幕，这里留出顶部胶囊按钮和安全距离的空间 */
  max-height: calc(50vh - 80px); 
}

.ai-bubble {
  background: #FFF9F0;
  border: 3px solid #E8D5C4;
  border-radius: 24px;
  box-shadow: 0 8px 16px rgba(0,0,0,0.08);
  position: relative;
  width: 100%;
  box-sizing: border-box;
  /* 让 scroll-view 的高度根据内容自适应，但受限于外层 max-height */
  height: auto; 
  max-height: 100%;
}

/* 内部内容增加 padding */
.bubble-content {
  padding: 16px 20px;
}

.msg-text {
  font-size: 16px;
  line-height: 1.5;
  color: #5D4037;
  font-weight: 500;
  word-break: break-all;
}

/* 富文本中的段落样式，控制段落间距 */
.msg-paragraph {
  margin-bottom: 6px; /* 减小换行后的空行高度 */
}
.msg-paragraph:last-child {
  margin-bottom: 0;
}

.bubble-tail {
  position: relative; /* 尾巴跟在气泡下面 */
  left: -25%; /* 偏左对齐狐狸 */
  width: 0;
  height: 0;
  border-left: 15px solid transparent;
  border-right: 15px solid transparent;
  border-top: 18px solid #E8D5C4;
  margin-top: -3px; /* 盖住一点点气泡的边框 */
  z-index: 4;
}

.bubble-tail::after {
  content: '';
  position: absolute;
  top: -19px;
  left: -11px;
  width: 0;
  height: 0;
  border-left: 11px solid transparent;
  border-right: 11px solid transparent;
  border-top: 14px solid #FFF9F0;
}

.bottom-padding {
  height: 160px; /* 留出底部按钮的空间，防止滚动不到底 */
}

.input-area {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 250px; /* 给整个操作区足够的高度，以便自由定位 */
  z-index: 10;
  pointer-events: none; /* 让空白区域不阻挡底层的点击事件 */
}

.btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: absolute; /* 使用绝对定位，打破传统的水平排列 */
  pointer-events: auto; /* 恢复按钮本身的点击能力 */
}

/* 语音按钮：放在正下方偏左一点（图中花朵的位置） */
.voice-btn-container {
  bottom: 40px;
  left: 45%;
  transform: translateX(-50%);
}

/* 文本按钮：放在右下角偏上（图中信箱的位置） */
.text-btn-container {
  bottom: 90px;
  right: 20px;
}

.btn-icon {
  width: 90px;
  height: 90px;
  margin-bottom: 8px;
  transition: all 0.2s ease;
  border-radius: 50%;
  border: 3px solid #fff;
  box-shadow: 0 6px 16px rgba(0,0,0,0.1);
  background: #fff;
}

/* 单独调整信箱大小，图里的信箱比话筒大一些 */
.text-icon {
  width: 110px;
  height: 110px;
}

.btn-icon:active {
  transform: scale(0.95);
}

.btn-text {
  background: rgba(255, 255, 255, 0.95);
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 14px;
  color: #5D4037;
  font-weight: bold;
  box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.text-bubble-hint {
  position: absolute;
  top: -15px; /* 根据变大的信箱调整位置 */
  left: 20px; /* 让气泡偏左一点，贴合图里的设计 */
  background: #fff;
  padding: 2px 10px;
  border-radius: 10px;
  font-size: 14px;
  color: #8D6E63;
  font-weight: bold;
  border: 1.5px dashed #D7CCC8;
  animation: float 2.5s ease-in-out infinite;
}

.text-bubble-hint::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  border-left: 5px solid transparent;
  border-right: 5px solid transparent;
  border-top: 6px solid #D7CCC8;
}

/* 动画效果 */
.floating {
  animation: float 2.5s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

.recording {
  animation: pulse 1.5s infinite;
  filter: drop-shadow(0 0 10px rgba(255, 138, 128, 0.8));
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

/* 文本输入弹窗 */
.text-input-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.text-input-box {
  background: #fff;
  padding: 16px 20px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
}

.input-element {
  flex: 1;
  background: #F5F5F5;
  height: 44px;
  border-radius: 22px;
  padding: 0 20px;
  font-size: 16px;
  color: #333;
}

.send-btn {
  margin-left: 16px;
  background: #FFCA28;
  color: #fff;
  padding: 0 24px;
  height: 44px;
  line-height: 44px;
  border-radius: 22px;
  font-weight: bold;
  font-size: 16px;
  box-shadow: 0 4px 10px rgba(255, 202, 40, 0.4);
}

.send-btn:active {
  background: #FFB300;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 24px;
  padding: 0 8px;
}
.dot {
  width: 8px;
  height: 8px;
  background: #8D6E63;
  border-radius: 50%;
  margin: 0 4px;
  animation: bounce 1.4s infinite ease-in-out both;
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}