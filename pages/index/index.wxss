page {
  height: 100%;
}

.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.chat-area {
  flex: 1;
  position: relative;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.ai-bubble-container {
  position: relative;
  margin: 20px auto 0;
  width: 85%;
  z-index: 5;
}

.ai-bubble {
  background: #FFF9F0;
  border: 3px solid #E8D5C4;
  border-radius: 24px;
  padding: 16px 20px;
  box-shadow: 0 8px 16px rgba(0,0,0,0.08);
  position: relative;
}

.msg-text {
  font-size: 17px;
  line-height: 1.6;
  color: #5D4037;
  font-weight: 500;
  word-break: break-all;
}

.bubble-tail {
  position: absolute;
  bottom: -15px;
  left: 30px;
  width: 0;
  height: 0;
  border-left: 15px solid transparent;
  border-right: 15px solid transparent;
  border-top: 18px solid #E8D5C4;
}

.bubble-tail::after {
  content: '';
  position: absolute;
  top: -19px;
  left: -11px;
  width: 0;
  height: 0;
  border-left: 11px solid transparent;
  border-right: 11px solid transparent;
  border-top: 14px solid #FFF9F0;
}

.bottom-padding {
  height: 160px; /* 留出底部按钮的空间，防止滚动不到底 */
}

.input-area {
  position: absolute;
  bottom: 40px;
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  z-index: 10;
  padding: 0 40px;
  box-sizing: border-box;
}

.btn-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.btn-icon {
  width: 120px;
  height: 120px;
  margin-bottom: 8px;
  transition: all 0.2s ease;
}

.btn-icon:active {
  transform: scale(0.95);
}

.btn-text {
  background: rgba(255, 255, 255, 0.95);
  padding: 4px 12px;
  border-radius: 12px;
  font-size: 14px;
  color: #5D4037;
  font-weight: bold;
  box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.text-bubble-hint {
  position: absolute;
  top: -20px;
  background: #fff;
  padding: 2px 10px;
  border-radius: 10px;
  font-size: 14px;
  color: #8D6E63;
  font-weight: bold;
  border: 1.5px dashed #D7CCC8;
  animation: float 2.5s ease-in-out infinite;
}

.text-bubble-hint::after {
  content: '';
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  border-left: 5px solid transparent;
  border-right: 5px solid transparent;
  border-top: 6px solid #D7CCC8;
}

/* 动画效果 */
.floating {
  animation: float 2.5s ease-in-out infinite;
}

@keyframes float {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

.recording {
  animation: pulse 1.5s infinite;
  filter: drop-shadow(0 0 10px rgba(255, 138, 128, 0.8));
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

/* 文本输入弹窗 */
.text-input-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.text-input-box {
  background: #fff;
  padding: 16px 20px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
}

.input-element {
  flex: 1;
  background: #F5F5F5;
  height: 44px;
  border-radius: 22px;
  padding: 0 20px;
  font-size: 16px;
  color: #333;
}

.send-btn {
  margin-left: 16px;
  background: #FFCA28;
  color: #fff;
  padding: 0 24px;
  height: 44px;
  line-height: 44px;
  border-radius: 22px;
  font-weight: bold;
  font-size: 16px;
  box-shadow: 0 4px 10px rgba(255, 202, 40, 0.4);
}

.send-btn:active {
  background: #FFB300;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 24px;
  padding: 0 8px;
}
.dot {
  width: 8px;
  height: 8px;
  background: #8D6E63;
  border-radius: 50%;
  margin: 0 4px;
  animation: bounce 1.4s infinite ease-in-out both;
}
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}