<view class="container">
  <!-- 背景，使用用户提供的第二张图片 -->
  <image class="bg-layer" src="/images/bg.png" mode="aspectFill"></image>
  
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <!-- 返回按钮 -->
    <view class="back-btn">
      <image src="/images/back.png" class="back-icon" mode="aspectFit"></image>
    </view>
    <view class="title">小朋友的AI探险</view>
  </view>

  <!-- 聊天区域，现在只显示最新的对话，并使用绝对定位模拟图1中的气泡位置 -->
  <view class="chat-area">
    <!-- AI气泡框（参考图1样式） -->
    <view class="ai-bubble-container" wx:if="{{latestAIMessage}}">
      <view class="ai-bubble">
        <text class="msg-text">{{latestAIMessage.content}}</text>
        <view class="loading" wx:if="{{latestAIMessage.loading}}">
          <view class="dot"></view><view class="dot"></view><view class="dot"></view>
        </view>
      </view>
      <!-- 气泡的小尾巴 -->
      <view class="bubble-tail"></view>
    </view>
    
    <!-- 用户提问气泡（暂不显示，或后续通过其他方式展示，目前先隐藏以贴合图1布局） -->
  </view>

  <!-- 底部操作区 -->
  <view class="input-area">
    <!-- 语音按钮 -->
    <view class="btn-container voice-btn-container" bindtouchstart="startRecord" bindtouchend="stopRecord">
      <image class="btn-icon voice-icon {{isRecording ? 'recording' : ''}}" src="https://coresg-normal.trae.ai/api/ide/v1/text_to_image?prompt=A%20cute%20cartoon%20toy%20microphone%20shaped%20like%20a%20colorful%20flower%20with%20a%20smiley%20face%20in%20the%20center%2C%20bright%20colors%2C%202D%20vector%20art%2C%20white%20background&image_size=square" mode="aspectFit"></image>
      <text class="btn-text">{{isRecording ? '松开 发送' : '说话提问'}}</text>
    </view>

    <!-- 文本按钮 -->
    <view class="btn-container text-btn-container" bindtap="toggleTextInput">
      <!-- 信箱图标上面有一个小气泡 -->
      <view class="text-bubble-hint">...</view>
      <image class="btn-icon text-icon floating" src="https://coresg-normal.trae.ai/api/ide/v1/text_to_image?prompt=A%20cute%20cartoon%20wooden%20mailbox%20toy%20with%20a%20red%20flag%20up%20and%20colorful%20toy%20blocks%20around%20it%2C%20bright%20colors%2C%202D%20vector%20art%2C%20white%20background&image_size=square" mode="aspectFit"></image>
      <text class="btn-text">输入问题</text>
    </view>
  </view>

  <!-- 文本输入弹窗 -->
  <view class="text-input-mask" wx:if="{{showTextInput}}" bindtap="toggleTextInput">
    <view class="text-input-box" catchtap="preventD">
      <input 
        class="input-element" 
        placeholder="想问什么呀？" 
        value="{{inputText}}" 
        bindinput="onInput" 
        confirm-type="send" 
        bindconfirm="sendText" 
        focus="{{showTextInput}}" 
      />
      <view class="send-btn" bindtap="sendText">发送</view>
    </view>
  </view>
</view>